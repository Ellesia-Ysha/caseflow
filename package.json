{
  "name": "caseflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A case-management dashboard demonstrating virtualized tables, URL-synced filtering, and optimistic updates at scale.",
  "scripts": {
    "predev": "npm run generate:data",
    "dev": "vite",
    "prebuild": "npm run generate:data",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "msw:init": "msw init public/",
    "generate:data": "node scripts/generate-mock-data.mjs"
  },
  "keywords": [],
  "author": "Ellesia Catherine Reyes",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.19",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "ecr-components": "^0.1.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "msw": "^2.15.0",
    "postcss": "^8.5.16",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
